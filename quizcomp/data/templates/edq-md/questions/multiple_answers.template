{% extends "questions/base.template" %}

{% block directions %}
Choose all that apply:

{% endblock %}

{% block body %}
{% for (marker, choice) in this.answers.get_choices_with_markers() %}
{% if (answer_key and choice.correct) %}
{{ marker.to_md() }}. {{ choice.text.to_md() }} *(correct)*  
{% else %}
{{ marker.to_md() }}. {{ choice.text.to_md() }}  
{% endif %}
{% endfor %}
{% endblock %}
