{% extends "questions/base.template" %}

{% block directions %}
For each part, choose one:

{% endblock %}

{% block body %}
{% for (label, part) in this.answers.parts.items() %}
{{ label }}:  
{% for (marker, choice) in part.get_choices_with_markers() %}
{% if (answer_key and choice.correct) %}
{{ marker.to_md() }}. {{ choice.text.to_md() }} *(correct)*  
{% else %}
{{ marker.to_md() }}. {{ choice.text.to_md() }}  
{% endif %}
{% endfor %}

{% endfor %}
{% endblock %}
