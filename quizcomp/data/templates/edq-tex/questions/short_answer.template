<% extends "questions/base.template" %>

<% set width = this.get_known_config('width') %>
<% set height = this.get_known_config('height') %>
<% set center = (not this.get_known_config('nocenter')) %>
<% set solution = this.answers.get_first_option_text().to_tex() if answer_key else '' %>

<% block directions_text %>
    Place your answer within the boxed region below.
<% endblock %>

<% block body %>
    <% if center %>
        \begin{center}
    <% endif %>

    \bigAnswerBox[<< solution >>]{<< height >>}{<< width >>}{short_answer}{<< id >>}{0}{0}

    <% if center %>
        \end{center}
    <% endif %>
<% endblock %>
