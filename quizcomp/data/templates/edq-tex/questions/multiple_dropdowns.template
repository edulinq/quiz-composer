<% extends "questions/base.template" %>

<% set inline = this.get_known_config('inline') %>
<% set default_width = 0.15 if (inline) else 0.80 %>
<% set width = this.get_known_config('width', default_width) %>
<% set center = (not this.get_known_config('nocenter')) %>

<% block directions_text %>
    For each part (denoted by angle brackets), fill in the circle that corresponds to your choice.
<% endblock %>

<% block body %>
    <% for (label, part) in this.answers.parts.items() %>
        <% set part_id = loop.index0 %>
        \end{minipage}

        <% if (not loop.first) %>
            \vspace{0.25cm}
        <% endif %>

        \begin{minipage}{\textwidth}

        \noindent
        << label >>:

        <% if center %>
            \begin{center}
        <% endif %>

        <% if (inline) %>
            <% for choice in part.choices %>
                <% set fill = '[red]' if (answer_key and choice.correct) else '' %>
                \begin{tabular}{ >{\centering\arraybackslash}m{0.06\textwidth} m{<< width >>\textwidth} }
                    \radio<< fill >>{multiple_dropdowns}{<< id >>}{<< id >>.<< part_id >>}{<< loop.index0 >>}
                        & << choice.text.to_tex() >> \\
                \end{tabular}
            <% endfor %>
        <% else %>
            \begin{tabular}{ >{\centering\arraybackslash}m{0.06\textwidth} m{<< width >>\textwidth} }
                <% for choice in part.choices %>
                    <% set fill = '[red]' if (answer_key and choice.correct) else '' %>
                    \radio<< fill >>{multiple_dropdowns}{<< id >>}{<< id >>.<< part_id >>}{<< loop.index0 >>}
                        & << choice.text.to_tex() >> \\
                <% endfor %>
            \end{tabular}
        <% endif %>

        <% if center %>
            \end{center}
        <% endif %>
    <% endfor %>
<% endblock %>
