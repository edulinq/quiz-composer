<% extends "questions/base.template" %>

<% set inline = this.get_known_config('inline') %>
<% set height = this.get_known_config('height') %>
<% set default_width = 0.13 if (inline) else 0.95 %>
<% set width = this.get_known_config('width', default_width) %>
<% set center = (not this.get_known_config('nocenter')) %>

<% block directions_text %>
    For each part (denoted by angle brackets), place your answer in the associated box.
<% endblock %>

<% block body %>
    <% if center %>
        \begin{center}
    <% endif %>

    <% for (label, text_answers) in this.answers.parts.items() %>
        <% if (inline) %>
            \begin{tabular}{ >{\centering\arraybackslash}m{0.05\textwidth} >{\centering\arraybackslash}m{<< width + 0.01 >>\textwidth} }
                << label >>: &
                <% if (answer_key) %>
                    \bigAnswerBox[<< text_answers.get_first_option_text().to_text() >>]{<< height >>}{<< width >>}{fill_in_multiple_blanks}{<< id >>}{<< id >>.<< loop.index0 >>}{0} \\
                <% else %>
                    \bigAnswerBox{<< height >>}{<< width >>}{fill_in_multiple_blanks}{<< id >>}{<< id >>.<< loop.index0 >>}{0} \\
                <% endif %>
            \end{tabular}
        <% else %>
            << label >>: \\
            <% if (answer_key) %>
                \bigAnswerBox[<< text_answers.get_first_option_text().to_text() >>]{<< height >>}{<< width >>}{fill_in_multiple_blanks}{<< id >>}{<< id >>.<< loop.index0 >>}{0} \\
            <% else %>
                \bigAnswerBox{<< height >>}{<< width >>}{fill_in_multiple_blanks}{<< id >>}{<< id >>.<< loop.index0 >>}{0} \\
            <% endif %>
        <% endif %>
    <% endfor %>

    <% if center %>
        \end{center}
    <% endif %>
<% endblock %>
