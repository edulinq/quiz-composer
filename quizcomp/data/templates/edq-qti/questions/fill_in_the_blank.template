{% extends "questions/base.template" %}

{% import 'questions/utils.template' as utils %}

{% block field_ids %}
    {{ utils.field_id_list(id, this.answers.options) }}
{% endblock %}

{% block body %}
    <response_str ident="response1" rcardinality="Single">
        <render_fib>
            <response_label ident="answer1" rshuffle="No"/>
        </render_fib>
    </response_str>
{% endblock %}

{% block scoring %}
    <resprocessing>
        <outcomes>
            <decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal"/>
        </outcomes>
        {% for option in this.answers.options %}
            {% set id = 'af' ~ id ~ 'f' ~ loop.index0 %}
            <respcondition continue="Yes">
                <conditionvar>
                    <varequal respident="response1">{{ option.text.to_html() }}</varequal>
                </conditionvar>
                <setvar varname="SCORE" action="Set">100</setvar>
            </respcondition>
            {% if ((option.feedback is not none) and (options.feedback.general is not none)) %}
                <displayfeedback feedbacktype="Response" linkrefid="{{ id }}_fb"/>
            {% endif %}
        {% endfor %}
    </resprocessing>
{% endblock %}

{% block additional_feedback %}
    {{ utils.options_feedback(id, this.answers.options) }}
{% endblock %}
