{% extends "questions/base.template" %}

{% block field_ids %}
    {% set ids = [] %}
    {% for part in this.answers.parts.values() %}
        {% set part_id = 'af' ~ id ~ 'f' ~ loop.index0 %}
        {% for choice in part.choices %}
            {% set choice_id = part_id ~ 'f' ~ loop.index0 %}
            {{ ids.append(choice_id) or '' }}
        {% endfor %}
    {% endfor %}
    {{- ids | join(',') -}}
{% endblock %}

{% block body %}
    {% for (label, part) in this.answers.parts.items() %}
        {% set part_id = 'af' ~ id ~ 'f' ~ loop.index0 %}
        {% set response_ref = 'response_' ~ label %}
        <response_lid ident="{{ response_ref }}">
            <material>
                <mattext>{{ part.label }}</mattext>
            </material>
            <render_choice>
                {% for choice in part.choices %}
                    {% set choice_id = part_id ~ 'f' ~ loop.index0 %}
                    <response_label ident="{{ choice_id }}">
                        <material>
                            <mattext texttype="text/plain">{{ choice.text.to_text() }}</mattext>
                        </material>
                    </response_label>
                {% endfor %}
            </render_choice>
        </response_lid>
    {% endfor %}
{% endblock %}

{% block scoring %}
    <resprocessing>
        <outcomes>
            <decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal"/>
        </outcomes>
        {% for(label, part) in this.answers.parts.items() %}
            {% set part_id = 'af' ~ id ~ 'f' ~ loop.index0 %}
            {% set response_ref = 'response_' ~ label %}
            {% for choice in part.choices %}
                {% set choice_id = part_id ~ 'f' ~ loop.index0 %}
                <respcondition continue="Yes">
                    <conditionvar>
                        <varequal respident="{{ response_ref }}">{{ choice_id }}</varequal>
                    </conditionvar>
                    {% if choice.correct %}
                        <setvar varname="SCORE" action="Add">{{ (100.0 / (this.answers.parts | length)) | round(2) }}</setvar>
                    {% endif %}
                    {% if choice.feedback %}
                        <displayfeedback feedbacktype="Response" linkrefid="{{ choice_id }}_fb"/>
                    {% endif %}
                </respcondition>
            {% endfor %}
        {% endfor %}
    </resprocessing>
{% endblock %}

{% block additional_feedback %}
    {% for part in this.answers.parts.values() %}
        {% set part_id = 'af' ~ id ~ 'f' ~ loop.index0 %}
        {% for choice in part.choices %}
            {% set choice_id = part_id ~ 'f' ~ loop.index0 %}
            {% if ((choice.feedback is not none) and (choice.feedback.general is not none)) %}
                <itemfeedback ident="{{ choice_id }}_fb">
                    <flow_mat>
                        <material>
                            <mattext texttype="text/html">
                                {{ choice.feedback.general.html() }}
                            </mattext>
                        </material>
                    </flow_mat>
                </itemfeedback>
            {% endif %}
        {% endfor %}
    {% endfor %}
{% endblock %}
