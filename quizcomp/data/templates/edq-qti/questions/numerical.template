{% extends "questions/base.template" %}

{% import 'questions/utils.template' as utils %}

{% block field_ids %}
    0
{% endblock %}

{% block body %}
    <response_str ident="response1" rcardinality="Single">
        <render_fib fibtype="Decimal">
            <response_label ident="answer1"/>
        </render_fib>
    </response_str>
{% endblock %}

{% block scoring %}
    <resprocessing>
        <outcomes>
            <decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal"/>
        </outcomes>
        {% for option in this.answers.options %}
            {% set id = 'af' ~ id ~ 'f' ~ loop.index0 %}
            <respcondition continue="No">
                <conditionvar>
                {% if (option.type == 'exact') %}
                    <or>
                        <varequal respident="response1">{{ option.value }}</varequal>
                        <and>
                            <vargte respident="response1">{{ option.value - option.margin }}</vargte>
                            <varlte respident="response1">{{ option.value + option.margin }}</varlte>
                        </and>
                    </or>
                {% elif (option.type == 'range') %}
                    <vargte respident="response1">{{ option.min }}</vargte>
                    <varlte respident="response1">{{ option.max }}</varlte>
                {% elif (option.type == 'precision') %}
                    {% set margin = (5 * (10 ** -(option.precision))) %}
                    <or>
                        <varequal respident="response1">{{ option.value }}</varequal>
                        <and>
                            <vargte respident="response1">{{ option.value - margin }}</vargte>
                            <varlte respident="response1">{{ option.value + margin }}</varlte>
                        </and>
                    </or>
                {% endif %}
                </conditionvar>
                <setvar action="Set" varname="SCORE">100</setvar>
                {% if ((option.feedback is not none) and (options.feedback.general is not none)) %}
                    <displayfeedback feedbacktype="Response" linkrefid="{{ id }}_fb"/>
                {% endif %}
            </respcondition>
        {% endfor %}
    </resprocessing>
{% endblock %}

{% block additional_feedback %}
    {{ utils.options_feedback(id, this.answers.options) }}
{% endblock %}
