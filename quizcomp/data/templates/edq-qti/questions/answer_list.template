{% macro field_ids(id, answers) %}
    {% for answer in answers %}
        {% set id = 'af' ~ id ~ 'f' ~ loop.index0 %}
        {% if not loop.last %}
                {% set id = id ~ ',' %}
        {% endif %}
        {{- id -}}
    {% endfor %}
{% endmacro %}

{% macro body(id, answers, cardinality = 'Single') %}
    <response_lid ident="response1" rcardinality="{{ cardinality }}">
        <render_choice>
            {% for answer in answers %}
                {% set id = 'af' ~ id ~ 'f' ~ loop.index0 %}
                <response_label ident="{{ id }}">
                <material>
                    <mattext texttype="text/html">{{ answer.text }}</mattext>
                </material>
                </response_label>
            {% endfor %}
        </render_choice>
    </response_lid>
{% endmacro %}

{% macro scoring(id, answers) %}
    <resprocessing>
        <outcomes>
            <decvar maxvalue="100" minvalue="0" varname="SCORE" vartype="Decimal"/>
        </outcomes>
        {% for answer in answers %}
            {% set id = 'af' ~ id ~ 'f' ~ loop.index0 %}
            <respcondition continue="Yes">
                <conditionvar>
                    <varequal respident="response1">{{ id }}</varequal>
                </conditionvar>
                {% if answer.correct %}
                    <setvar action="Set" varname="SCORE">100</setvar>
                {% endif %}
                {% if answer.feedback %}
                    <displayfeedback feedbacktype="Response" linkrefid="{{ id }}_fb"/>
                {% endif %}
            </respcondition>
        {% endfor %}
    </resprocessing>
{% endmacro %}

{% macro feedback(id, answers) %}
    {% for answer in answers %}
        {% set id = 'af' ~ id ~ 'f' ~ loop.index0 %}
        {% if answer.feedback %}
            <itemfeedback ident="{{ id }}_fb">
                <flow_mat>
                    <material>
                        <mattext texttype="text/html">
                            {{ answer.feedback }}
                        </mattext>
                    </material>
                </flow_mat>
            </itemfeedback>
        {% endif %}
    {% endfor %}
{% endmacro %}
