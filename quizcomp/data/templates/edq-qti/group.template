<section ident="group_{{ id }}" title="{{ this.name }}">
    <selection_ordering>
        <selection>
            <selection_number>{{ this.pick_count }}</selection_number>
            <selection_extension>
                <points_per_item>{{ this.get_points() }}</points_per_item>
            </selection_extension>
        </selection>
    </selection_ordering>
    {{ children_content }}
</section>
