<div class='qg-quiz-question{% if answer_key %} qg-answer-key{% endif %}' data-type='{{ question.question_type }}' data-number='{{ question.number }}' data-name='{{ question.name }}' data-points='{{ question.points }}'>
    {% if question.custom_header is none %}
        <h2 class='qg-quiz-question-name'>Question {{ question.number }} <span class='qg-quiz-question-points'>({{ question.points }} Points)</span></h2>
    {% elif question.custom_header != '' %}
        <h2 class='qg-quiz-question-name'>{{ question.custom_header }}</h2>
    {% else %}
        <!-- No Header. -->
    {% endif %}

    <div class='qg-quiz-question-prompt'>
        {{ question.prompt_text }}
    </div>

    <p class='qg-quiz-question-directions'>
        {% block directions %}
        {% endblock %}
    </p>

    <div class='qg-quiz-question-body'>
        {% block body required %}
        {% endblock %}
    </div>
</div>
