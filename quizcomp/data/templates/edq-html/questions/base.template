<hr />

<div class='qg-quiz-question{% if answer_key %} qg-answer-key{% endif %}' data-type='{{ this.question_type }}' data-number='{{ number }}' data-name='{{ this.name }}' data-points='{{ this.get_points() }}'>
    {% if custom_header is not none %}
        <h2 class='qg-quiz-question-name'>{{ custom_header.to_html() }}</h2>
    {% elif (number is not none) %}
        <h2 class='qg-quiz-question-name'>Question {{ number }} <span class='qg-quiz-question-points'>({{ this.get_display_points() }} Points)</span></h2>
    {% else %}
        <!-- No Header. -->
    {% endif %}

    <div class='qg-quiz-question-prompt'>
        {{ this.prompt.to_html() }}
    </div>

    <p class='qg-quiz-question-directions'>
        {% block directions %}
        {% endblock %}
    </p>

    <div class='qg-quiz-question-body'>
        {% block body required %}
        {% endblock %}
    </div>
</div>
