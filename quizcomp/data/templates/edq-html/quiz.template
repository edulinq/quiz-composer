<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="utf-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">

        <title>{{ quiz.title }}</title>

        <style>
            {{ css_content }}
        </style>
    </head>
    <body>
        <div class='qg-quiz'>
            <form class='qg-quiz-form'>
                <div class='qg-quiz-header'>
                    <h1>{{ quiz.title }}</h1>
                    <p>{{ quiz.course_title }} &mdash; {{ quiz.term_title }}</p>
                    <p>{{ quiz.date }}</p>
                    <p>Total Points: {{ quiz.total_points }}</p>
                </div>

                {% if quiz.description_text %}
                <div class='qg-quiz-description'>
                    {{ quiz.description_text }}
                </div>
                {% endif %}

                <div class='qg-quiz-body'>
                    {{ inner_text }}

                    <hr>

                    <input type='submit' value='Submit Quiz' />
                </div>
            </form>
        </div>
    </body>
</html>
