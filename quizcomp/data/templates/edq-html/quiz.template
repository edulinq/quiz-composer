<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="utf-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">

        <title>{{ this.name }}</title>

        {% if css_content %}
        <style>
            {{ css_content }}
        </style>
        {% endif %}
    </head>
    <body>
        <div class='qg-quiz'>
            <form class='qg-quiz-form'>
                <div class='qg-quiz-header'>
                    <h1>{{ this.name }}</h1>

                    {% if (this.course_name is not none) and (this.term_name is not none) %}
                        <p>{{ this.course_name }} &mdash; {{ this.term_name }}</p>
                    {% elif (this.course_name is not none) %}
                        <p>{{ this.course_name }}</p>
                    {% elif (this.term_name is not none) %}
                        <p>{{ this.term_name }}</p>
                    {% endif %}

                    {% if (this.date is not none) %}
                        <p>{{ this.date.strftime("%Y-%m-%d") }}</p>
                    {% endif %}

                    <p>Total Points: {{ this.get_points() }}</p>
                </div>

                <div class='qg-quiz-description'>
                    {{ this.description.to_html() }}
                </div>

                <div class='qg-quiz-body'>
                    {{ children_content }}

                    <hr />

                    <input type='submit' value='Submit Quiz'>
                </div>
            </form>
        </div>
    </body>
</html>
